{
  "schema_version": 1,
  "manifest_version": "v1",
  "description": "Shadow changed-path verification planner — named checks, globs, dependencies, Full triggers. Toolkit-only; does not run CI.",
  "profile_quick_stage_count": 13,
  "profile_full_oracle_stage_count": 13,
  "profile_full_total_stage_count": 26,
  "current_full_runtime_observed": "2m25s",
  "graduation_gates": {
    "p95_minutes_min": 5,
    "min_ci_runs": 20,
    "min_patches_same_sha": 30,
    "max_patches_same_sha": 60,
    "median_patches_min": 25,
    "zero_selector_misses": true,
    "promotion_status": "evidence_pending"
  },
  "conservative_full_triggers": [
    "missing_history",
    "merge_conflict",
    "parse_error",
    "unknown_path",
    "unknown_event",
    "workflow_change",
    "bootstrap_change",
    "shipping_manifest_change",
    "planner_change",
    "plugin_mirror_change",
    "shared_contract_change",
    "pre_merge",
    "push_main",
    "dispatch_explicit",
    "release"
  ],
  "release_trigger_globs": [
    "docs/project-state.md",
    "CHANGELOG.md"
  ],
  "full_trigger_globs": [
    ".github/workflows/**",
    "scripts/smoke-bootstrap.ps1",
    "scripts/verify-harness.ps1",
    "scripts/bootstrap-into-project.ps1",
    "scripts/new-project.ps1",
    "shipping/manifest.v1.json",
    "shipping/verification-checks.v1.json",
    "scripts/plan-verification.ps1",
    "plugin/**",
    ".cursor/skills/autonomous-task/contracts.md",
    ".cursor/skills/autonomous-task/tier-rubric.md",
    "schemas/**",
    "subagents/**",
    "tests/portability/**"
  ],
  "checks": [
    {
      "id": "Q-PARSE",
      "profile": "quick",
      "script": "scripts/parse-check-ps1.ps1",
      "path_globs": ["**/*.ps1"],
      "dependencies": [],
      "timeout_seconds": 120,
      "stage_token": "Q-PARSE"
    },
    {
      "id": "Q-DOCS-ST",
      "profile": "quick",
      "script": "scripts/validate-project-docs.ps1",
      "script_args": ["-SelfTest"],
      "path_globs": [
        "docs/docs-map.json",
        "docs/docs-map-schema.md",
        "scripts/validate-project-docs.ps1",
        "docs/**"
      ],
      "dependencies": [],
      "timeout_seconds": 60,
      "stage_token": "Q-DOCS-ST"
    },
    {
      "id": "Q-DOCS-LIVE",
      "profile": "quick",
      "script": "scripts/validate-project-docs.ps1",
      "script_args": ["-ProjectRoot", "<toolkit-root>"],
      "path_globs": ["docs/**", "AGENTS.md", "README.md"],
      "dependencies": ["Q-DOCS-ST"],
      "timeout_seconds": 60,
      "stage_token": "Q-DOCS-LIVE"
    },
    {
      "id": "Q-ORCH-ST",
      "profile": "quick",
      "script": "scripts/validate-orchestration.ps1",
      "script_args": ["-SelfTest"],
