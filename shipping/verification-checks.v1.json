        "scripts/validate-orchestration.ps1",
        "subagents/**",
        ".cursor/skills/autonomous-task/**",
        "docs/autonomous-agent-orchestration.md",
        "docs/orchestration-evidence.md"
      ],
      "dependencies": [],
      "timeout_seconds": 90,
      "stage_token": "Q-ORCH-ST"
    },
    {
      "id": "Q-MCP-ST",
      "profile": "quick",
      "script": "scripts/validate-mcp-profiles.ps1",
