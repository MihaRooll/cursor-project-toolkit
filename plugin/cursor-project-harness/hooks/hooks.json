{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ./scripts/session-start.ps1",
        "timeout": 15
      }
    ],
    "afterShellExecution": [
      {
        "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ./scripts/after-shell-papercuts.ps1",
        "timeout": 20
      }
    ],
    "stop": [
      {
        "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ./scripts/stop-papercuts-nudge.ps1",
        "timeout": 15
      }
    ]
  }
}
